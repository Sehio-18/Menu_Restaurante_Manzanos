---
import BotonVolver from '../components/boton_volver.astro';
import FiltroAlergenos from '../components/filtro_alergenos.astro';

const { title } = Astro.props;
const url = Astro.url.pathname;

const lang = url.includes('/en/') ? 'en' : url.includes('/de/') ? 'de' : url.includes('/it/') ? 'it' : url.includes('/fr/') ? 'fr' : 'es';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>
    
    <header class="nav-superior">
        <BotonVolver />
    </header>

    <div class="main-container">
        <FiltroAlergenos />
        <slot />
    </div>

    <div id="global-modal" class="modal-overlay" onclick="closeModal()">
        <span class="close-btn">&times;</span>
        <img id="modal-img" src="" alt="Cargando..." />
        <h4 id="modal-title"></h4>
    </div>

    <style is:global>
        :root { 
            --dorado: #c5a059; 
            --fondo: #121212; 
            /* ESCALADO GLOBAL: Bajamos a 14px para que todo se vea más fino en el móvil */
            font-size: 14px;
        }

        @media (min-width: 768px) {
            :root { font-size: 16px; }
        }

        body {
            margin: 0; 
            background: var(--fondo) url('/textura_negro_cuero.png') repeat fixed;
            color: #fdfaf5; 
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden; 
        }

        .nav-superior {
            display: flex;
            align-items: center;
            padding: 1rem 1.5rem; /* Reducido un poco para ganar espacio arriba */
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .main-container { 
            max-width: 600px; /* Estrechado para que en móviles anchos no se vea raro */
            margin: 0 auto; 
            padding: 0.5rem 1rem 120px; /* Reducido márgenes laterales */
        }
        
        /* AJUSTES PARA EL MODAL (IMÁGENES AMPLIADAS) */
        .modal-overlay {
            display: none; 
            position: fixed; 
            top: 0; 
            left: 0; 
            width: 100%; 
            height: 100%;
            background: rgba(0,0,0,0.95); 
            z-index: 10000; 
            backdrop-filter: blur(10px);
            align-items: center; 
            justify-content: center; 
            flex-direction: column;
            cursor: pointer;
        }

        .modal-overlay img { 
            max-width: 90%; /* Ajustado para que ocupe casi toda la pantalla del móvil */
            max-height: 65vh; 
            border: 1px solid var(--dorado); 
            border-radius: 12px;
            box-shadow: 0 0 30px rgba(0,0,0,0.8);
            animation: zoomIn 0.3s ease;
        }

        #modal-title { 
            color: var(--dorado); 
            font-family: 'Playfair Display', serif; 
            margin-top: 12px; 
            font-size: 1.3rem; /* Título del plato en el modal más pequeño */
            text-transform: uppercase; 
            text-align: center;
            padding: 0 10px;
        }

        .close-btn { 
            position: absolute; 
            top: 15px; 
            right: 20px; 
            color: white; 
            font-size: 40px; /* Aspa de cierre más discreta */
            cursor: pointer; 
        }
        
        @keyframes zoomIn { 
            from { opacity: 0; transform: scale(0.95); } 
            to { opacity: 1; transform: scale(1); } 
        }

        /* Estilo extra por si los títulos de platos dentro del slot son h2 */
        h2 { font-size: 1.5rem !important; }
    </style>

    <script is:inline>
        window.openModal = function(src, title) {
            const modal = document.getElementById('global-modal');
            const img = document.getElementById('modal-img');
            const titleEl = document.getElementById('modal-title');
            
            img.src = src;
            titleEl.innerText = title;
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        window.closeModal = function() {
            document.getElementById('global-modal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }
    </script>
</body>
</html>
