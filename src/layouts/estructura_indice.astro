<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>Restaurante Los Manzanos | Carta Digital</title>
    <meta name="description" content="Consulta la carta digital del Restaurante Los Manzanos. Arroces, carnes y pescados con la mejor tradición." />
    
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>
    <div class="main-container">
        <slot />
    </div>

    <style is:global>
        :root {
            --dorado: #c5a059;
            --fondo: #121212;
        }

        /* --- TÍTULO CON EFECTO DE BRILLO --- */
        .titulo-principal {
            font-family: 'Playfair Display', serif;
            color: var(--dorado) !important;
            font-size: 3rem;
            letter-spacing: 5px;
            text-transform: uppercase;
            margin: 0.5rem 0 1.5rem;
            
            background: linear-gradient(
                90deg,
                rgba(197, 160, 89, 1) 0%, 
                rgba(255, 255, 255, 1) 40%, 
                rgba(197, 160, 89, 1) 100%
            );
            background-size: 200% auto;
            color: transparent;
            -webkit-background-clip: text;
            background-clip: text;
            animation: brilloDorado 5s linear infinite;
        }

        @keyframes brilloDorado {
            0% { background-position: -100% 0; }
            100% { background-position: 100% 0; }
        }

        /* --- ESTILO DEL CUERPO --- */
        body {
            margin: 0;
            background-color: var(--fondo) !important;
            background-image: url('/textura_negro_cuero.png') !important;
            background-repeat: repeat;
            background-attachment: fixed;
            color: #fdfaf5;
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* --- CONTENEDOR PRINCIPAL --- */
        .main-container {
            background: transparent !important;
            width: 100%;
            max-width: 400px;
            text-align: center;
            padding: 2rem;
            margin: 0 auto;
        }
    </style>
</body>
</html>
