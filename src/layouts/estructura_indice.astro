<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>Restaurante Los Manzanos | Carta Digital</title>
    <meta name="description" content="Consulta la carta digital del Restaurante Los Manzanos. Arroces, carnes y pescados con la mejor tradición." />
    
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>
    <div class="main-container">
        <slot />
    </div>

    <style is:global>
        :root {
            --dorado: #c5a059;
            --fondo: #121212;
            /* REDUCIMOS LA BASE: Antes era 16px por defecto, ahora 14px para que todo lo que use 'rem' baje de tamaño */
            font-size: 14px; 
        }

        @media (min-width: 768px) {
            :root {
                font-size: 16px; /* En ordenadores vuelve al tamaño normal */
            }
        }

        /* --- TÍTULO AJUSTADO (Más pequeño y elegante) --- */
        .titulo-principal {
            font-family: 'Playfair Display', serif;
            color: var(--dorado) !important;
            font-size: 2.2rem; /* Bajado de 3rem */
            letter-spacing: 3px; /* Menos agresivo */
            text-transform: uppercase;
            margin: 1rem 0 2rem;
            line-height: 1.1;
            
            background: linear-gradient(
                90deg,
                rgba(197, 160, 89, 1) 0%, 
                rgba(255, 255, 255, 1) 40%, 
                rgba(197, 160, 89, 1) 100%
            );
            background-size: 200% auto;
            color: transparent;
            -webkit-background-clip: text;
            background-clip: text;
            animation: brilloDorado 5s linear infinite;
        }

        @keyframes brilloDorado {
            0% { background-position: -100% 0; }
            100% { background-position: 100% 0; }
        }

        /* --- CUERPO --- */
        body {
            margin: 0;
            background-color: var(--fondo) !important;
            background-image: url('/textura_negro_cuero.png') !important;
            background-repeat: repeat;
            background-attachment: fixed;
            color: #fdfaf5;
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            /* Añadimos un poco de aire arriba */
            padding-top: 40px;
        }

        /* --- CONTENEDOR AJUSTADO --- */
        .main-container {
            background: transparent !important;
            width: 90%; /* Ocupa el 90% del ancho del móvil */
            max-width: 340px; /* Un poco más estrecho para que sea más estilizado */
            text-align: center;
            padding: 1rem 0;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 0.8rem; /* Espacio entre botones más compacto */
        }

        /* Ajuste para los botones de idioma si usas etiquetas <a> */
        .main-container a {
            text-decoration: none;
            width: 100%;
        }
    </style>
</body>
</html>
