---
import EstructuraPag from '../../layouts/estructura_pag.astro';
import LeyendaAlergenos from '../../components/leyenda_alergenos.astro';
import TituloSeccion from '../../components/titulo_seccion.astro';
import MenuDesplegable from '../../components/menu_desplegable.astro';
import DisenoPlato from '../../components/diseno_plato.astro';
import DisenoBebida from '../../components/diseno_bebida.astro';
import { ui } from '../../data/ui.js';
const url = Astro.url.pathname;
const segments = url.split('/');
const lang = segments.find(s => ['en', 'it', 'de', 'fr'].includes(s)) || 'es';
const t = (key) => ui[lang]?.[key] || ui['es'][key];
---

<EstructuraPag title="Carta - Los Manzanos">
    
    <LeyendaAlergenos />

    <main>
        <TituloSeccion titulo="OUR DISHES" />
        
        <MenuDesplegable titulo="Starters">
            <DisenoPlato id="vieiras" />
            <DisenoPlato id="langostinos" />
            <DisenoPlato id="pastel" />
            <DisenoPlato id="cecina" />
            <DisenoPlato id="empanada" />
            <DisenoPlato id="foie" />
            <DisenoPlato id="navajas" />
            <DisenoPlato id="croquetas" />
            </MenuDesplegable>

        <MenuDesplegable titulo="Seafood">
            <p class="advertencia-interna">
                "All prices shown are per person, and a minimum order for two people is required"
            </p>
            <DisenoPlato id="arrozNegro" />
            <DisenoPlato id="arrozBogavante" />
            <DisenoPlato id="arrozMarineiro" />
             <DisenoPlato id="fidegua" />
            </MenuDesplegable>

        <MenuDesplegable titulo="Meat Dishes">
            <DisenoPlato id="cochinillo" />
            <DisenoPlato id="solomillo" />
            <DisenoPlato id="solomilloRoquefort" />
            <DisenoPlato id="entrecot" />
        </MenuDesplegable>

        <MenuDesplegable titulo="Fish">
            <DisenoPlato id="rapeSugerencia" />
            <DisenoPlato id="lubinaSugerencia" />
            <DisenoPlato id="bacalaoManzanos" />
            <DisenoPlato id="bacalaoDourado" />
        </MenuDesplegable>

        <TituloSeccion titulo="OVEN TO TABLE" />
        
        <MenuDesplegable titulo="Pizzas">
            <p class="advertencia-interna">
                "Homemade Italian dough. Topped with tomato sauce, mozzarella and oregano (all pizzas)."
            </p>
            <DisenoPlato id="pizzaMargarita" tieneFoto={false}/>
            <DisenoPlato id="pizzaMixta" tieneFoto={false}/>
            <DisenoPlato id="pizzaCaprichosa" tieneFoto={false}/>
            <DisenoPlato id="pizzaCantabrica" tieneFoto={false}/>
            <DisenoPlato id="pizzaSiciliana" tieneFoto={false}/>
            <DisenoPlato id="pizzaCuatroQuesos" tieneFoto={false}/>
            <DisenoPlato id="pizzaDelPais" tieneFoto={false}/>
            <DisenoPlato id="pizzaAtlantica" tieneFoto={false}/>
            <DisenoPlato id="pizzaCampista" tieneFoto={false}/>
            <DisenoPlato id="pizzaTresSabores" tieneFoto={false}/>
            <DisenoPlato id="pizzaVegetariana" tieneFoto={false}/>
            </MenuDesplegable>
        
        
        <TituloSeccion titulo="OUR SWEET TREATS" />
        
        <MenuDesplegable titulo="Postres">
            <DisenoPlato id="tartaCastana" />
            <DisenoPlato id="tocinilloCielo" />
            <DisenoPlato id="brownie" />
            <DisenoPlato id="tartaQueso" />
            <DisenoPlato id="heladosSurtidos" />
            <DisenoPlato id="tiramisu" />
            <DisenoPlato id="heladoDulceLeche" />
            <DisenoPlato id="falsoTomate" />
            <DisenoPlato id="bolaHelado" />
            </MenuDesplegable>
        
        <TituloSeccion titulo="Wines" />

<MenuDesplegable titulo="Wines by the glass">
    {/* Para copas, usamos labelCopa */}
    <DisenoBebida id="copaAlbarino" tieneDescripcion={false} labelCopa="Copa" />
    <DisenoBebida id="copaGodello" tieneDescripcion={false} labelCopa="Copa" />
    <DisenoBebida id="copaRibeiro" tieneDescripcion={false} labelCopa="Copa" />
    <DisenoBebida id="copaRibera" tieneDescripcion={false} labelCopa="Copa" />
    <DisenoBebida id="copaRioja" tieneDescripcion={false} labelCopa="Copa" />
    <DisenoBebida id="copaMencia" tieneDescripcion={false} labelCopa="Copa" />  
</MenuDesplegable>

