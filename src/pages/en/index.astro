</MenuDesplegable>

    </main>

    
    <style>
        .advertencia-interna {
            font-size: 0.85rem;
            color: var(--dorado); /* Color dorado para que destaque con elegancia */
            font-style: italic;
            text-align: center;
            margin: 0 1rem 2rem 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px dashed rgba(197, 160, 89, 0.3); /* Línea discontinua dorada */
            display: block;
            line-height: 1.4;
        }

        main {
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            padding: 0 1.5rem 5rem;
        }
    </style>

</EstructuraPag>
