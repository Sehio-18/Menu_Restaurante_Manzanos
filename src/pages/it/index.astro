---
import EstructuraPag from '../../layouts/estructura_pag.astro';
import LeyendaAlergenos from '../../components/leyenda_alergenos.astro';
import TituloSeccion from '../../components/titulo_seccion.astro';
import MenuDesplegable from '../../components/menu_desplegable.astro';
import DisenoPlato from '../../components/diseno_plato.astro';
import DisenoBebida from '../../components/diseno_bebida.astro';
import { ui } from '../../data/ui.js';
const url = Astro.url.pathname;
const segments = url.split('/');
const lang = segments.find(s => ['en', 'it', 'de', 'fr'].includes(s)) || 'es';
const t = (key) => ui[lang]?.[key] || ui['es'][key];
---

