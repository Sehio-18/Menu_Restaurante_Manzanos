---
import { ui } from '../data/ui.js';

const url = Astro.url.pathname;
const segments = url.split('/');
const lang = segments.find(s => ['en', 'it', 'de', 'fr'].includes(s)) || 'es';
const t = (key) => ui[lang]?.[key] || ui['es'][key];

const todosLosAlergenos = [
  'gluten', 'crustaceos', 'huevos', 'pescado',
  'soja', 'lacteos', 'moluscos', 'frutos-secos'
];
---

<div class="grupo-categoria">
  <p class="titulo-leyenda">{t('info.alergenos')}:</p>

  <div class="rejilla-leyenda">
    {todosLosAlergenos.map((item) => (
      <div class="item-leyenda">
        <img src={`/assets/alergenos/${item}.svg`} alt={t(`alergenos.${item}`)} class="icono-leyenda" />
        <span class="nombre-alergeno">{t(`alergenos.${item}`)}</span>
      </div>
    ))}
  </div>
</div>

<style>
  /* Caja idéntica a .grupo-categoria de menu_desplegable.astro */
  .grupo-categoria {
    background: rgba(26, 26, 26, 0.8);
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    overflow: hidden;
    transition: all 0.3s ease;
    padding: 1.5rem;
  }

  .titulo-leyenda {
    margin: 0 0 1.2rem 0;
    color: var(--dorado);
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-weight: 600;
  }

  /* 4 columnas iguales, ocupa todo el ancho de la caja */
  .rejilla-leyenda {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.9rem 0.5rem;
  }

  .item-leyenda {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .icono-leyenda {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    filter: sepia(0.5) brightness(0.9);
  }

  .nombre-alergeno {
    font-size: 0.8rem;
    color: #e0e0e0;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
