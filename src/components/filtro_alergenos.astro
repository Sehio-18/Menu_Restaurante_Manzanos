---
import { ui } from '../data/ui.js';

const url = Astro.url.pathname;
const segments = url.split('/');
const lang = segments.find(s => ['en', 'it', 'de', 'fr'].includes(s)) || 'es';
const t = (key) => ui[lang]?.[key] || ui['es'][key];

const listaAlergenos = [
  { id: 'gluten',       icon: 'gluten.svg' },
  { id: 'crustaceos',   icon: 'crustaceos.svg' },
  { id: 'huevos',       icon: 'huevos.svg' },
  { id: 'pescado',      icon: 'pescado.svg' },
  { id: 'soja',         icon: 'soja.svg' },
  { id: 'lacteos',      icon: 'lacteos.svg' },
  { id: 'moluscos',     icon: 'moluscos.svg' },
  { id: 'frutos-secos', icon: 'frutos-secos.svg' },
];
---

<div class="grupo-categoria">
  <p class="filtro-instrucciones">{t('info.filtro_instrucciones')}</p>

  <div class="iconos-filtro">
    {listaAlergenos.map(a => (
      <button class="btn-filtro" data-alergeno={a.id} title={t(`alergenos.${a.id}`)}>
        <img src={`/assets/alergenos/${a.icon}`} alt={a.id} />
        <span class="prohibido">/</span>
      </button>
    ))}
  </div>
</div>

<style>
  /* Caja idéntica a .grupo-categoria de menu_desplegable.astro */
  .grupo-categoria {
    background: rgba(26, 26, 26, 0.8);
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    overflow: hidden;
    transition: all 0.3s ease;
    padding: 1.5rem;
    text-align: center;
  }

  .filtro-instrucciones {
    margin: 0 0 1.2rem 0;
    color: var(--dorado);
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-weight: 600;
  }

  /* Grid de 4 columnas con ancho exacto: 4×50px + 3×15px = 245px, centrado */
  .iconos-filtro {
    display: grid;
    grid-template-columns: repeat(4, 50px);
    grid-template-rows: repeat(2, 50px);
    gap: 15px;
    width: max-content;
    margin: 0 auto;
  }

  .btn-filtro {
    position: relative;
    background: #1a1a1a;
    border: 2px solid rgba(197, 160, 89, 0.2);
    border-radius: 50%;
    width: 50px;
    height: 50px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    padding: 0;
  }

  .btn-filtro img {
    width: 28px;
    height: 28px;
    opacity: 0.7;
  }

  .btn-filtro.active {
    border-color: #ff4444;
    background: #2a1010;
    transform: scale(1.1);
  }
  .btn-filtro.active img { opacity: 1; }

  .prohibido {
    position: absolute;
    color: #ff4444;
    font-size: 35px;
    font-weight: bold;
    display: none;
    pointer-events: none;
    line-height: 1;
  }
  .btn-filtro.active .prohibido { display: block; }
</style>

<script>
  function ejecutarFiltro() {
    document.querySelectorAll('.btn-filtro').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('active');

        const activos = Array.from(document.querySelectorAll('.btn-filtro.active'))
                             .map(b => b.getAttribute('data-alergeno'));

        document.querySelectorAll('.plato-card').forEach(plato => {
          const alergenosPlato = (plato.getAttribute('data-alergenos') || '').split(',');
          const tieneConflicto = activos.some(a => alergenosPlato.includes(a));
          plato.style.display = tieneConflicto ? 'none' : 'block';
        });
      });
    });
  }

  ejecutarFiltro();
</script>
