---
// src/components/titulo_seccion.astro
const { titulo } = Astro.props;
---

<div class="contenedor-seccion-estatica">
  <h2 class="titulo-grande">{titulo}</h2>
  <div class="separador-dorado"></div>
</div>

<style>
  .contenedor-seccion-estatica {
    text-align: center;
    margin: 4rem 0 2rem; /* Mucho espacio arriba para separar grupos */
  }

  .titulo-grande {
    font-family: 'Playfair Display', serif;
    color: var(--dorado, #c5a059);
    font-size: 2.2rem;
    letter-spacing: 5px;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
    font-weight: 700;
  }

  .separador-dorado {
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--dorado, #c5a059), transparent);
    opacity: 0.8;
  }
</style>